--- !u!114 &980891351
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 980891350}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: fd2b7c65ca7132c44b5a0bdae262dfdf, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  questions:
  - questionText: "\u041A\u0430\u043A\u0443\u044E \u0445\u0443\u0434\u043E\u0436\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0443\u044E
      \u0442\u0435\u0445\u043D\u0438\u043A\u0443 \u043C\u043E\u0436\u043D\u043E \u0443\u0437\u043D\u0430\u0442\u044C,
      \u043F\u043E\u0441\u0435\u0449\u0430\u044F \u044D\u043A\u0441\u043F\u043E\u0437\u0438\u0446\u0438\u0438
      \u0445\u0443\u0434\u043E\u0436\u043D\u0438\u043A\u0430 \u0420\u044B\u0441\u0443\u0445\u0438\u043D\u0430?"
    answers:
    - "\u0410\u043A\u0432\u0430\u0440\u0435\u043B\u044C"
    - "\u041B\u0435\u0432\u043A\u0430\u0441"
    - "\u0413\u0440\u0430\u0444\u0444\u0438\u0442\u0438"
    - "\u041F\u0430\u0441\u0442\u0435\u043B\u044C"
    correctAnswerIndex: 1
    fact: "\u0425\u0443\u0434\u043E\u0436\u043D\u0438\u043A \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442
      \u0432 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u0436\u0438\u0432\u043E\u043F\u0438\u0441\u0438
      \u0434\u0440\u0435\u0432\u043D\u044E\u044E \u0442\u0435\u0445\u043D\u0438\u043A\u0443
      \u043B\u0435\u0432\u043A\u0430\u0441\u0430 \u2014 \u0442\u043E\u0442 \u0436\u0435
      \u0433\u0440\u0443\u043D\u0442, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
      \u043F\u0440\u0438\u043C\u0435\u043D\u044F\u043B\u0438 \u043C\u0430\u0441\u0442\u0435\u0440\u0430
      \u0440\u0443\u0441\u0441\u043A\u043E\u0439 \u0438\u043A\u043E\u043D\u043E\u043F\u0438\u0441\u0438"
  - questionText: "\u041A\u0430\u043A\u043E\u0439 \u044D\u043B\u0435\u043C\u0435\u043D\u0442
      \u0447\u0430\u0449\u0435 \u0432\u0441\u0435\u0433\u043E \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F
      \u0434\u043B\u044F \u043F\u0435\u0440\u0435\u0434\u0430\u0447\u0438 \u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0438
      \u0446\u0438\u0440\u043A\u043E\u0432\u043E\u0433\u043E \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u044F
      \u0432 \u0436\u0438\u0432\u043E\u043F\u0438\u0441\u0438"
    answers:
    - "\u0421\u0442\u0430\u0442\u0438\u0447\u043D\u044B\u0435 \u043F\u043E\u0437\u044B"
    - "\u0427\u0451\u0440\u043D\u043E-\u0431\u0435\u043B\u0430\u044F \u0433\u0430\u043C\u043C\u0430"
    - "\u0413\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0435
      \u0444\u0438\u0433\u0443\u0440\u044B"
    - "\u0414\u0432\u0438\u0436\u0435\u043D\u0438\u0435 \u0438 \u044F\u0440\u043A\u0438\u0435
      \u0446\u0432\u0435\u0442\u0430"
    correctAnswerIndex: 3
    fact: "\u0425\u0443\u0434\u043E\u0436\u043D\u0438\u043A\u0438 \u0446\u0438\u0440\u043A\u043E\u0432\u043E\u0439
      \u0442\u0435\u043C\u044B \u0447\u0430\u0441\u0442\u043E **\u0438\u0441\u043A\u0430\u0436\u0430\u044E\u0442
      \u043F\u043E\u0437\u044B \u0438 \u043B\u0438\u043D\u0438\u0438**, \u0447\u0442\u043E\u0431\u044B
      \u043F\u0435\u0440\u0435\u0434\u0430\u0442\u044C \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u044C
      \u0438 \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435. \u0422\u0430\u043A\u043E\u0439
      \u043F\u0440\u0438\u0451\u043C \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
      \u041C\u0430\u0440\u043A \u0428\u0430\u0433\u0430\u043B, \u0438\u0437\u043E\u0431\u0440\u0430\u0436\u0430\u044F
      \u043B\u0435\u0442\u0430\u044E\u0449\u0438\u0445 \u0430\u043A\u0440\u043E\u0431\u0430\u0442\u043E\u0432
      \u0438 \u043A\u043B\u043E\u0443\u043D\u043E\u0432. "
  - questionText: "\u041F\u043E\u0447\u0435\u043C\u0443 \u0432 \u043C\u0443\u0437\u0435\u044F\u0445
      \u0447\u0430\u0441\u0442\u043E \u043D\u0435\u043B\u044C\u0437\u044F \u0444\u043E\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u0440\u043E\u0432\u0430\u0442\u044C
      \u0441\u043E \u0432\u0441\u043F\u044B\u0448\u043A\u043E\u0439?"
    answers:
    - "\u0421\u0432\u0435\u0442 \u043C\u043E\u0436\u0435\u0442 \u043F\u043E\u0432\u0440\u0435\u0434\u0438\u0442\u044C
      \u043A\u0440\u0430\u0441\u043A\u0438 \u043A\u0430\u0440\u0442\u0438\u043D"
    - "\u042D\u0442\u043E \u043C\u0435\u0448\u0430\u0435\u0442 \u043E\u0445\u0440\u0430\u043D\u0435"
    - "\u041A\u0430\u043C\u0435\u0440\u0430 \u043F\u043B\u043E\u0445\u043E \u0441\u043D\u0438\u043C\u0430\u0435\u0442"
    - "\u0424\u043E\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u0438 \u043F\u043E\u043B\u0443\u0447\u0430\u044E\u0442\u0441\u044F
      \u0441\u043B\u0438\u0448\u043A\u043E\u043C \u044F\u0440\u043A\u0438\u043C\u0438"
    correctAnswerIndex: 0
    fact: "\u042F\u0440\u043A\u0438\u0439 \u0441\u0432\u0435\u0442 \u043C\u043E\u0436\u0435\u0442
      \u043F\u043E\u0441\u0442\u0435\u043F\u0435\u043D\u043D\u043E \u0432\u044B\u0446\u0432\u0435\u0442\u0430\u0442\u044C
      \u043F\u0438\u0433\u043C\u0435\u043D\u0442\u044B \u0432 \u043A\u0430\u0440\u0442\u0438\u043D\u0430\u0445
      \u0438 \u0441\u0442\u0430\u0440\u044B\u0445 \u0444\u043E\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u044F\u0445.
      \u041F\u043E\u044D\u0442\u043E\u043C\u0443 \u0434\u0430\u0436\u0435 \u0432
      \u0442\u0430\u043A\u0438\u0445 \u043C\u0443\u0437\u0435\u044F\u0445, \u043A\u0430\u043A
      \u041B\u0443\u0432\u0440 \u0438 \u0413\u043E\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
      \u042D\u0440\u043C\u0438\u0442\u0430\u0436, \u0432\u043E \u043C\u043D\u043E\u0433\u0438\u0445
      \u0437\u0430\u043B\u0430\u0445 \u0437\u0430\u043F\u0440\u0435\u0449\u0430\u044E\u0442
      \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C \u0432\u0441\u043F\u044B\u0448\u043A\u0443,
      \u0447\u0442\u043E\u0431\u044B \u043B\u0443\u0447\u0448\u0435 \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u0442\u044C
      \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u0434\u0435\u043D\u0438\u044F \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0430."
  - questionText: "\u041A\u0430\u043A\u043E\u0435 \u043D\u043E\u0432\u043E\u0435
      \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E \u0434\u043B\u044F
      \u0445\u0443\u0434\u043E\u0436\u043D\u0438\u043A\u043E\u0432 \u0441\u043E\u0437\u0434\u0430\u043D\u043E
      \u0432 \u043C\u0443\u0437\u0435\u0435?"
    answers:
    - "\u0422\u0435\u0430\u0442\u0440\u0430\u043B\u044C\u043D\u0430\u044F \u0441\u0446\u0435\u043D\u0430"
    - "\u041C\u0443\u0437\u044B\u043A\u0430\u043B\u044C\u043D\u0430\u044F \u0441\u0442\u0443\u0434\u0438\u044F"
    - "\u0422\u0430\u043D\u0446\u0435\u0432\u0430\u043B\u044C\u043D\u044B\u0439 \u0437\u0430\u043B"
    - "\u0410\u0440\u0442-\u0440\u0435\u0437\u0438\u0434\u0435\u043D\u0446\u0438\u044F
      \u0434\u043B\u044F \u0445\u0443\u0434\u043E\u0436\u043D\u0438\u043A\u043E\u0432"
    correctAnswerIndex: 3
    fact: "\u0412 \u0430\u0440\u0442-\u0440\u0435\u0437\u0438\u0434\u0435\u043D\u0446\u0438\u0438
      \u0445\u0443\u0434\u043E\u0436\u043D\u0438\u043A\u0438 \u043C\u043E\u0433\u0443\u0442
      \u0436\u0438\u0442\u044C \u0438 \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C
      \u043F\u0440\u044F\u043C\u043E \u0432 \u043C\u0443\u0437\u0435\u0435, \u0441\u043E\u0437\u0434\u0430\u0432\u0430\u044F
      \u043D\u043E\u0432\u044B\u0435 \u043F\u0440\u043E\u0435\u043A\u0442\u044B.
      \u0418\u043D\u043E\u0433\u0434\u0430 \u043F\u043E\u0441\u0435\u0442\u0438\u0442\u0435\u043B\u0438
      \u043C\u043E\u0433\u0443\u0442 \u0443\u0432\u0438\u0434\u0435\u0442\u044C \u043F\u0440\u043E\u0446\u0435\u0441\u0441
      \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044F \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0430
      \u043F\u043E\u0447\u0442\u0438 \u0432\u0436\u0438\u0432\u0443\u044E"
  - questionText: "\u041F\u043E\u0447\u0435\u043C\u0443 \u043C\u0443\u0437\u0435\u0439
      \u041C\u2019\u0410\u0420\u0422 \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F
      \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u044B\u043C \u0434\u043B\u044F
      \u0440\u0435\u0433\u0438\u043E\u043D\u0430?"
    answers:
    - "\u042D\u0442\u043E \u0441\u0430\u043C\u044B\u0439 \u0441\u0442\u0430\u0440\u044B\u0439
      \u043C\u0443\u0437\u0435\u0439"
    - "\u0422\u0430\u043C \u043D\u0435\u0442 \u043A\u0430\u0440\u0442\u0438\u043D"
    - "\u042D\u0442\u043E \u043A\u0440\u0443\u043F\u043D\u0435\u0439\u0448\u0438\u0439
      \u0438 \u0441\u0430\u043C\u044B\u0439 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0439
      \u0433\u043E\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
      \u043C\u0443\u0437\u0435\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438"
    - "\u041E\u043D \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442 \u0442\u043E\u043B\u044C\u043A\u043E
      \u043B\u0435\u0442\u043E\u043C"
    correctAnswerIndex: 2
    fact: "\u041C\u0443\u0437\u0435\u0439 \u041C\u2019\u0410\u0420\u0422 \u0440\u0430\u0441\u043F\u043E\u043B\u043E\u0436\u0435\u043D
      \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u043C
      \u0437\u0434\u0430\u043D\u0438\u0438 \u041E\u0440\u0434\u043E\u043D\u0430\u043D\u0441\u0433\u0430\u0443\u0437,
      \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u043F\u043E\u0441\u043B\u0435 \u0440\u0435\u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0446\u0438\u0438
      \u0441\u0442\u0430\u043B\u043E \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u043C
      \u0432\u044B\u0441\u0442\u0430\u0432\u043E\u0447\u043D\u044B\u043C \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E\u043C
      \u0441 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E\u043C \u0437\u0430\u043B\u043E\u0432. "
  - questionText: "\u041A\u0430\u043A\u0438\u0435 \u043C\u0435\u0440\u043E\u043F\u0440\u0438\u044F\u0442\u0438\u044F
      \u043A\u0440\u043E\u043C\u0435 \u0432\u044B\u0441\u0442\u0430\u0432\u043E\u043A
      \u043F\u0440\u043E\u0445\u043E\u0434\u044F\u0442 \u0432 \u043C\u0443\u0437\u0435\u0435?"
    answers:
    - "\u0421\u043F\u043E\u0440\u0442\u0438\u0432\u043D\u044B\u0435 \u0441\u043E\u0440\u0435\u0432\u043D\u043E\u0432\u0430\u043D\u0438\u044F"
    - "\u041B\u0435\u043A\u0446\u0438\u0438, \u0432\u0441\u0442\u0440\u0435\u0447\u0438
      \u0438 \u043C\u0430\u0441\u0442\u0435\u0440-\u043A\u043B\u0430\u0441\u0441\u044B"
    - "\u041A\u043E\u043D\u0446\u0435\u0440\u0442\u044B"
    - "\u0424\u0443\u0442\u0431\u043E\u043B\u044C\u043D\u044B\u0435 \u043C\u0430\u0442\u0447\u0438"
    correctAnswerIndex: 1
    fact: "\u0412 \u043C\u0443\u0437\u0435\u044F\u0445 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E
      \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0430 \u043C\u043E\u0436\u043D\u043E
      \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0441\u043C\u043E\u0442\u0440\u0435\u0442\u044C
      \u043A\u0430\u0440\u0442\u0438\u043D\u044B, \u043D\u043E \u0438 **\u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u0442\u044C
      \u0432 \u043C\u0430\u0441\u0442\u0435\u0440-\u043A\u043B\u0430\u0441\u0441\u0430\u0445
      \u0438 \u0432\u0441\u0442\u0440\u0435\u0447\u0430\u0442\u044C\u0441\u044F \u0441
      \u0445\u0443\u0434\u043E\u0436\u043D\u0438\u043A\u0430\u043C\u0438**, \u0443\u0437\u043D\u0430\u0432\u0430\u044F,
      \u043A\u0430\u043A \u0441\u043E\u0437\u0434\u0430\u0451\u0442\u0441\u044F \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u043E.
      \U0001F3A8 "
  - questionText: "\u041A\u0430\u043A \u043D\u0430\u0437\u044B\u0432\u0430\u0435\u0442\u0441\u044F
      \u0445\u0443\u0434\u043E\u0436\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
      \u043F\u0440\u0438\u0451\u043C, \u043A\u043E\u0433\u0434\u0430 \u043A\u0440\u0430\u0441\u043A\u0430
      \u043D\u0430\u043D\u043E\u0441\u0438\u0442\u0441\u044F \u0433\u0443\u0441\u0442\u044B\u043C\u0438
      \u043C\u0430\u0437\u043A\u0430\u043C\u0438?"
    answers:
    - "\u0418\u043C\u043F\u0430\u0441\u0442\u043E"
    - "\u041B\u0435\u0441\u0441\u0438\u0440\u043E\u0432\u043A\u0430"
    - "\u0424\u0440\u0435\u0441\u043A\u0430"
    - "\u0413\u0440\u0430\u0432\u044E\u0440\u0430"
    correctAnswerIndex: 0
    fact: "\u041F\u0440\u0438 \u0438\u043C\u043F\u0430\u0441\u0442\u043E \u043A\u0440\u0430\u0441\u043A\u0430
      \u0432\u044B\u0441\u0442\u0443\u043F\u0430\u0435\u0442 \u043D\u0430\u0434 \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u044C\u044E
      \u043A\u0430\u0440\u0442\u0438\u043D\u044B \u0438 \u0441\u043E\u0437\u0434\u0430\u0451\u0442
      \u0440\u0435\u043B\u044C\u0435\u0444\u043D\u0443\u044E \u0442\u0435\u043A\u0441\u0442\u0443\u0440\u0443."
  - questionText: "\u041A\u0430\u043A \u043D\u0430\u0437\u044B\u0432\u0430\u0435\u0442\u0441\u044F
      \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u0434\u0435\u043D\u0438\u0435 \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0430,
      \u0441\u043E\u0437\u0434\u0430\u043D\u043D\u043E\u0435 \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u043E
      \u0434\u043B\u044F \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0451\u043D\u043D\u043E\u0433\u043E
      \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430 \u043C\u0443\u0437\u0435\u044F?"
    answers:
    - "\u042D\u0441\u043A\u0438\u0437"
    - "\u041F\u043E\u0440\u0442\u0440\u0435\u0442"
    - "\u0421\u0430\u0439\u0442-\u0441\u043F\u0435\u0446\u0438\u0444\u0438\u043A
      (site-specific)"
    - "\u0420\u0435\u043F\u0440\u043E\u0434\u0443\u043A\u0446\u0438\u044F"
    correctAnswerIndex: 2
    fact: "\u0422\u0430\u043A\u0438\u0435 \u0440\u0430\u0431\u043E\u0442\u044B \u0441\u043E\u0437\u0434\u0430\u044E\u0442\u0441\u044F
      \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u043E \u043F\u043E\u0434
      \u043A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u044B\u0439 \u0437\u0430\u043B
      \u0438\u043B\u0438 \u043C\u0435\u0441\u0442\u043E."
  - questionText: "\u0427\u0442\u043E \u0442\u0430\u043A\u043E\u0435 \u0438\u043D\u0441\u0442\u0430\u043B\u043B\u044F\u0446\u0438\u044F,
      \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u043C\u043E\u0436\u043D\u043E \u0443\u0432\u0438\u0434\u0435\u0442\u044C
      \u043D\u0430 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445
      \u0432\u044B\u0441\u0442\u0430\u0432\u043A\u0430\u0445 \u043C\u0443\u0437\u0435\u044F?"
    answers:
    - "\u041A\u0430\u0440\u0442\u0438\u043D\u0430 \u0432 \u0440\u0430\u043C\u043A\u0435"
    - "\u0421\u043A\u0443\u043B\u044C\u043F\u0442\u0443\u0440\u0430 \u0438\u0437
      \u043A\u0430\u043C\u043D\u044F"
    - "\u0413\u0440\u0430\u0432\u044E\u0440\u0430 \u043D\u0430 \u0431\u0443\u043C\u0430\u0433\u0435"
    - "\u041A\u043E\u043C\u043F\u043E\u0437\u0438\u0446\u0438\u044F \u0438\u0437
      \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u043E\u0432, \u0440\u0430\u0437\u043C\u0435\u0449\u0451\u043D\u043D\u044B\u0445
      \u0432 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0435"
    correctAnswerIndex: 3
    fact: "\u0418\u043D\u0441\u0442\u0430\u043B\u043B\u044F\u0446\u0438\u0438 \u0447\u0430\u0441\u0442\u043E
      \u0441\u043E\u0437\u0434\u0430\u044E\u0442\u0441\u044F \u0442\u0430\u043A,
      \u0447\u0442\u043E\u0431\u044B \u0437\u0440\u0438\u0442\u0435\u043B\u044C \u043C\u043E\u0433
      \u0432\u0437\u0430\u0438\u043C\u043E\u0434\u0435\u0439\u0441\u0442\u0432\u043E\u0432\u0430\u0442\u044C
      \u0441 \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u0434\u0435\u043D\u0438\u0435\u043C."
  - questionText: "\u041A\u0430\u043A\u043E\u0439 \u0438\u0437 \u044D\u0442\u0438\u0445
      \u0446\u0432\u0435\u0442\u043E\u0432 \u041D\u0415 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
      \u043E\u0441\u043D\u043E\u0432\u043D\u044B\u043C (\u0431\u0430\u0437\u043E\u0432\u044B\u043C)
      \u0432 \u0436\u0438\u0432\u043E\u043F\u0438\u0441\u0438?"
    answers:
    - "\u041A\u0440\u0430\u0441\u043D\u044B\u0439"
    - "\u0421\u0438\u043D\u0438\u0439"
    - "\u0417\u0435\u043B\u0451\u043D\u044B\u0439"
    - "\u0416\u0451\u043B\u0442\u044B\u0439"
    correctAnswerIndex: 3
    fact: "\u0417\u0435\u043B\u0451\u043D\u044B\u0439 \u043F\u043E\u043B\u0443\u0447\u0430\u0435\u0442\u0441\u044F
      \u043F\u0440\u0438 \u0441\u043C\u0435\u0448\u0435\u043D\u0438\u0438 \u0436\u0451\u043B\u0442\u043E\u0433\u043E
      \u0438 \u0441\u0438\u043D\u0435\u0433\u043E, \u0430 \u043D\u0430\u0448 \u0433\u043B\u0430\u0437
      \u043B\u0443\u0447\u0448\u0435 \u0432\u0441\u0435\u0433\u043E \u0440\u0430\u0437\u043B\u0438\u0447\u0430\u0435\u0442
      \u0438\u043C\u0435\u043D\u043D\u043E \u044D\u0442\u043E\u0442 \u0446\u0432\u0435\u0442"
  - questionText: "\u041A\u0430\u043A\u043E\u0439 \u0442\u0435\u0440\u043C\u0438\u043D
      \u043E\u0431\u043E\u0437\u043D\u0430\u0447\u0430\u0435\u0442 \u043F\u043E\u0432\u0442\u043E\u0440\u044F\u044E\u0449\u0438\u0439\u0441\u044F
      \u0441\u0442\u0438\u043B\u044C \u0438\u043B\u0438 \u043F\u0440\u0438\u0451\u043C
      \u0445\u0443\u0434\u043E\u0436\u043D\u0438\u043A\u0430?"
    answers:
    - "\u041F\u0435\u0440\u0441\u043F\u0435\u043A\u0442\u0438\u0432\u0430"
    - "\u041C\u043E\u0442\u0438\u0432"
    - "\u041A\u043E\u043D\u0442\u0440\u0430\u0441\u0442"
    - "\u042D\u0441\u043A\u0438\u0437"
    correctAnswerIndex: 2
    fact: "\u0423 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0445\u0443\u0434\u043E\u0436\u043D\u0438\u043A\u043E\u0432
      \u043C\u043E\u0442\u0438\u0432 \u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0441\u044F
      \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u0443\u0437\u043D\u0430\u0432\u0430\u0435\u043C\u044B\u043C,
      \u0447\u0442\u043E \u043F\u043E \u043D\u0435\u043C\u0443 \u043C\u043E\u0436\u043D\u043E
      \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u0442\u044C \u0430\u0432\u0442\u043E\u0440\u0430
      \u0434\u0430\u0436\u0435 \u0431\u0435\u0437 \u043F\u043E\u0434\u043F\u0438\u0441\u0438
      \u2014 \u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u043F\u043E\u0432\u0442\u043E\u0440\u044F\u044E\u0449\u0438\u0435\u0441\u044F
      \u043A\u0443\u0432\u0448\u0438\u043D\u043A\u0438 \u0443 \u041C\u043E\u043D\u0435"
  - questionText: "\u041A\u0430\u043A\u043E\u0435 \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435
      \u0441\u0432\u044F\u0437\u0430\u043D\u043E \u0441 \u0438\u0437\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0435\u043C
      \u0441\u0443\u0431\u044A\u0435\u043A\u0442\u0438\u0432\u043D\u044B\u0445 \u044D\u043C\u043E\u0446\u0438\u0439
      \u0447\u0435\u0440\u0435\u0437 \u0438\u0441\u043A\u0430\u0436\u0451\u043D\u043D\u044B\u0435
      \u0444\u043E\u0440\u043C\u044B \u0438 \u0446\u0432\u0435\u0442\u0430?"
    answers:
    - "\u0420\u0435\u0430\u043B\u0438\u0437\u043C"
    - "\u0418\u043C\u043F\u0440\u0435\u0441\u0441\u0438\u043E\u043D\u0438\u0437\u043C"
    - "\u042D\u043A\u0441\u043F\u0440\u0435\u0441\u0441\u0438\u043E\u043D\u0438\u0437\u043C"
    - "\u041A\u043B\u0430\u0441\u0441\u0438\u0446\u0438\u0437\u043C"
    correctAnswerIndex: 3
    fact: "\u0425\u0443\u0434\u043E\u0436\u043D\u0438\u043A\u0438-\u044D\u043A\u0441\u043F\u0440\u0435\u0441\u0441\u0438\u043E\u043D\u0438\u0441\u0442\u044B
      \u0447\u0430\u0441\u0442\u043E \u0436\u0435\u0440\u0442\u0432\u043E\u0432\u0430\u043B\u0438
      \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C\u044E \u0440\u0430\u0434\u0438
      \u0441\u0438\u043B\u044C\u043D\u043E\u0433\u043E \u044D\u043C\u043E\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u0433\u043E
      \u0443\u0434\u0430\u0440\u0430."
